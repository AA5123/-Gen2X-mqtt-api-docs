              "example": {
                "command": "set_impinjGen2X",
                "command_id": "a3987547-62a8-4005-a064-485524e25bff",
                "payload": {
                  "tagFocus": {
                    "enabled": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success response on `controlresponse` topic",
