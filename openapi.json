{
  "openapi": "3.0.3",
  "info": {
    "title": "Impinj Gen2X MQTT API",
    "version": "1.0.0",
    "description": "MQTT-based API for controlling Impinj Gen2X features on an RFID reader.\n\n## Connection Details\n| Parameter | Value |\n|-----------|-------|\n| Protocol | MQTT over TLS |\n| Broker | 10.117.229.9:8883 |\n| Publish Topic | `controlrequest` |\n| Subscribe Topic | `controlresponse` |\n| Tag Data Topic | `tagdatanew` |\n| Auth | Mutual TLS (CA cert + client cert + client key) |\n\n## Workflow\n1. Configure Gen2X features using `set_impinjGen2X`\n2. Verify configuration using `get_impinjGen2X`\n3. Stop the radio if running\n4. Start the radio with `applyImpinjGen2X: true`",
    "contact": {
      "name": "IoT-Connector Team"
    }
  },
  "servers": [
    {
      "url": "mqtt://10.117.229.9:8883",
      "description": "RFID Reader MQTT Broker (Mutual TLS)"
    }
  ],
  "tags": [
    { "name": "Protected Mode", "description": "Makes tags invisible unless the correct 32-bit password is provided" },
    { "name": "FastID", "description": "Tags return EPC + TID in a single inventory response" },
    { "name": "TagFocus", "description": "Already-inventoried tags stay unresponsive to help find unread tags" },
    { "name": "TagQuieting", "description": "Selectively silence/restore specific tags by EPC (M700/M800 chips)" },
    { "name": "Configuration", "description": "Retrieve current Gen2X settings" },
    { "name": "Radio Control", "description": "Start/stop the radio with Gen2X configuration" },
    { "name": "Tag Data", "description": "Real-time RFID tag read events from the reader" }
  ],
  "paths": {
    "/controlrequest/enableTagProtection": {
      "post": {
        "tags": ["Protected Mode"],
        "summary": "Enable Tag Protection",
        "description": "Makes a specific tag invisible to all RFID readers. Only readers with the correct password can see or interact with the tag after protection is enabled.\n\n**Topic:** `controlrequest`\n\n**Response Topic:** `controlresponse`",
        "operationId": "enableTagProtection",
        "requestBody": {
          "description": "Enable tag protection command",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TagProtectRequest" },
              "example": {
                "command": "set_impinjGen2X",
                "command_id": "345d9511-40ac-4aed-894f-006df1205b99",
                "payload": {
                  "tagProtect": {
                    "action": "enableTagProtection",
                    "password": "77777777",
                    "tagID": "12348765a5050076c4d75211"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success response on `controlresponse` topic",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Gen2XResponse" },
                "example": {
                  "command": "set_impinjGen2X",
                  "command_id": "345d9511-40ac-4aed-894f-006df1205b99",
                  "payload": {
                    "message": "Success: Gen2X configured. Use applyImpinjGen2X flag in start command to apply features."
                  },
                  "response": "success"
                }
              }
            }
          }
        }
      }
    },
    "/controlrequest/disableTagProtection": {
      "post": {
        "tags": ["Protected Mode"],
        "summary": "Disable Tag Protection",
        "description": "Removes protection from a specific tag, making it visible to all readers again without needing a password.\n\n**Topic:** `controlrequest`\n\n**Response Topic:** `controlresponse`",
        "operationId": "disableTagProtection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TagProtectRequest" },
              "example": {
                "command": "set_impinjGen2X",
                "command_id": "a157818d-9667-4d9f-8181-114ab48306f6",
                "payload": {
                  "tagProtect": {
                    "action": "disableTagProtection",
                    "password": "77777777",
                    "tagID": "12348765a5050076c4d75211"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success response on `controlresponse` topic",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Gen2XResponse" },
                "example": {
                  "command": "set_impinjGen2X",
                  "command_id": "a157818d-9667-4d9f-8181-114ab48306f6",
                  "payload": {
                    "message": "Success: Gen2X configured. Use applyImpinjGen2X flag in start command to apply features."
                  },
                  "response": "success"
                }
              }
            }
          }
        }
      }
    },
