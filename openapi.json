        "operationId": "quietTags",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TagQuietingRequest" },
              "example": {
                "command": "set_impinjGen2X",
                "command_id": "43505552-cb1b-406c-a027-cf101f576034",
                "payload": {
                  "tagQuieting": {
                    "basic": {
                      "action": "quiet",
                      "tagIDs": [
                        "e28011b0a5050076c4d751e9",
                        "e28011b0a5050076c4d77307",
                        "e28011b0a5050076c4d751ec",
                        "e28011b0a5050076c4d7530a",
                        "e28011b0a5050076c4d751e4"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success response on `controlresponse` topic",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Gen2XResponse" },
                "example": {
                  "command": "set_impinjGen2X",
                  "command_id": "43505552-cb1b-406c-a027-cf101f576034",
                  "payload": {
                    "message": "Success: Gen2X configured. Use applyImpinjGen2X flag in start command to apply features."
                  },
                  "response": "success"
                }
              }
            }
          }
        }
      }
    },
