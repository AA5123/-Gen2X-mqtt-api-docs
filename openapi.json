              }
            }
          }
        }
      }
    },
    "/controlrequest/enableFastID": {
      "post": {
        "tags": ["FastID"],
        "summary": "Enable FastID",
        "description": "Enables Impinj FastID so tags return both their EPC and TID in a single inventory response. Faster and more efficient inventory.\n\n**Topic:** `controlrequest`\n\n**Response Topic:** `controlresponse`",
        "operationId": "enableFastID",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FastIDRequest" },
              "example": {
                "command": "set_impinjGen2X",
                "command_id": "657298d3-98de-421c-9b7c-ad3b53b7474f",
                "payload": {
                  "fastID": {
                    "enabled": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
