    "/controlrequest/startWithGen2X": {
      "post": {
        "tags": ["Radio Control"],
        "summary": "Start Radio with Gen2X",
        "description": "Starts the radio with all configured Gen2X settings applied. **The radio must be stopped first before issuing this command.**\n\n**Topic:** `controlrequest`\n\n**Response Topic:** `controlresponse`",
        "operationId": "startWithGen2X",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StartRequest" },
              "example": {
                "command": "start",
                "command_id": "81dd51a2-b0d3-4099-b46a-5a3f82796ba1",
                "payload": {
                  "applyImpinjGen2X": true
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success response on `controlresponse` topic",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Gen2XResponse" },
                "example": {
                  "command": "start",
                  "command_id": "81dd51a2-b0d3-4099-b46a-5a3f82796ba1",
                  "payload": {},
                  "response": "success"
                }
              }
            }
          }
        }
      }
    },
    "/tagdatanew": {
      "get": {
        "tags": ["Tag Data"],
        "summary": "Tag Data Event (Subscribe)",
        "description": "Subscribe to `tagdatanew` topic to receive real-time RFID tag read events. Each message contains tag identity, signal strength, antenna, and timing data.\n\n**Topic:** `tagdatanew`",
        "operationId": "tagDataEvent",
        "responses": {
          "200": {
            "description": "Tag read event received on `tagdatanew` topic",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TagDataEvent" },
                "example": {
                  "data": {
                    "CRC": "715f",
                    "PC": "3000",
                    "antenna": 5,
                    "channel": 920.75,
                    "eventNum": 2845128,
                    "format": "epc",
                    "idHex": "12348765a5050076c4d75211",
                    "peakRssi": -41,
                    "phase": -89.89,
                    "reads": 1
                  },
                  "timestamp": "2026-04-01T05:40:35.721+0000",
                  "type": "CUSTOM"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TagProtectRequest": {
        "type": "object",
        "required": ["command", "command_id", "payload"],
        "properties": {
          "command": { "type": "string", "example": "set_impinjGen2X" },
          "command_id": { "type": "string", "format": "uuid", "description": "Unique ID to correlate request with response" },
          "payload": {
            "type": "object",
            "properties": {
              "tagProtect": {
                "type": "object",
                "required": ["action", "password", "tagID"],
                "properties": {
                  "action": { "type": "string", "enum": ["enableTagProtection", "disableTagProtection"], "description": "Operation to perform" },
                  "password": { "type": "string", "pattern": "^[0-9a-fA-F]{8}$", "description": "8-character hex password (e.g., 77777777)" },
                  "tagID": { "type": "string", "description": "Hex EPC of the target tag" }
                }
              }
            }
          }
        }
      },
      "TagVisibilityRequest": {
        "type": "object",
        "required": ["command", "command_id", "payload"],
        "properties": {
          "command": { "type": "string", "example": "set_impinjGen2X" },
          "command_id": { "type": "string", "format": "uuid" },
          "payload": {
            "type": "object",
            "properties": {
              "tagProtect": {
                "type": "object",
                "required": ["action", "password"],
                "properties": {
                  "action": { "type": "string", "enum": ["enableTagVisibility", "disableTagVisibility"] },
                  "password": { "type": "string", "pattern": "^[0-9a-fA-F]{8}$", "description": "8-character hex password" }
                }
              }
            }
          }
        }
      },
      "ShortRangeRequest": {
        "type": "object",
        "required": ["command", "command_id", "payload"],
        "properties": {
          "command": { "type": "string", "example": "set_impinjGen2X" },
          "command_id": { "type": "string", "format": "uuid" },
          "payload": {
            "type": "object",
            "properties": {
              "tagProtect": {
                "type": "object",
                "required": ["action", "password", "tagID", "enableShortRange"],
                "properties": {
                  "action": { "type": "string", "const": "enableTagProtection" },
                  "password": { "type": "string", "pattern": "^[0-9a-fA-F]{8}$" },
                  "tagID": { "type": "string", "description": "Hex EPC of the target tag" },
                  "enableShortRange": { "type": "boolean", "description": "true to enable short-range mode" }
                }
              }
            }
          }
        }
      },
      "FastIDRequest": {
        "type": "object",
        "required": ["command", "command_id", "payload"],
        "properties": {
          "command": { "type": "string", "example": "set_impinjGen2X" },
          "command_id": { "type": "string", "format": "uuid" },
          "payload": {
            "type": "object",
            "properties": {
              "fastID": {
                "type": "object",
                "required": ["enabled"],
                "properties": {
                  "enabled": { "type": "boolean", "description": "true to enable, false to disable FastID" }
                }
              }
            }
          }
        }
      },
      "TagFocusRequest": {
        "type": "object",
        "required": ["command", "command_id", "payload"],
        "properties": {
          "command": { "type": "string", "example": "set_impinjGen2X" },
          "command_id": { "type": "string", "format": "uuid" },
          "payload": {
            "type": "object",
            "properties": {
              "tagFocus": {
                "type": "object",
                "required": ["enabled"],
                "properties": {
                  "enabled": { "type": "boolean", "description": "true to enable, false to disable TagFocus" }
                }
              }
            }
          }
        }
      },
      "TagQuietingRequest": {
        "type": "object",
        "required": ["command", "command_id", "payload"],
        "properties": {
          "command": { "type": "string", "example": "set_impinjGen2X" },
          "command_id": { "type": "string", "format": "uuid" },
          "payload": {
            "type": "object",
            "properties": {
              "tagQuieting": {
                "type": "object",
                "properties": {
                  "basic": {
                    "type": "object",
                    "required": ["action", "tagIDs"],
                    "properties": {
                      "action": { "type": "string", "enum": ["quiet", "unquiet"], "description": "quiet to silence, unquiet to restore" },
                      "tagIDs": { "type": "array", "items": { "type": "string" }, "description": "List of tag EPCs (hex strings)" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "GetConfigRequest": {
        "type": "object",
        "required": ["command", "command_id", "payload"],
        "properties": {
          "command": { "type": "string", "example": "get_impinjGen2X" },
          "command_id": { "type": "string", "format": "uuid" },
          "payload": { "type": "object" }
        }
      },
      "StartRequest": {
        "type": "object",
        "required": ["command", "command_id", "payload"],
        "properties": {
          "command": { "type": "string", "example": "start" },
          "command_id": { "type": "string", "format": "uuid" },
          "payload": {
            "type": "object",
            "required": ["applyImpinjGen2X"],
            "properties": {
              "applyImpinjGen2X": { "type": "boolean", "description": "true to apply Gen2X config when starting" }
            }
          }
        }
      },
      "Gen2XResponse": {
        "type": "object",
        "properties": {
          "command": { "type": "string", "description": "Echoed command name" },
          "command_id": { "type": "string", "format": "uuid", "description": "Matches the request command_id" },
          "payload": {
            "type": "object",
            "properties": {
              "message": { "type": "string", "description": "Human-readable result message" }
            }
          },
          "response": { "type": "string", "enum": ["success", "failure"], "description": "Result status" }
        }
      },
      "TagDataEvent": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "CRC": { "type": "string", "description": "Tag CRC value (hex)" },
              "PC": { "type": "string", "description": "Protocol Control word (hex)" },
              "antenna": { "type": "integer", "description": "Antenna number that read the tag" },
              "channel": { "type": "number", "description": "RF channel frequency in MHz" },
              "eventNum": { "type": "integer", "description": "Event sequence number" },
              "format": { "type": "string", "description": "Data format (e.g., epc)" },
              "idHex": { "type": "string", "description": "Tag EPC in hexadecimal" },
              "peakRssi": { "type": "number", "description": "Peak RSSI in dBm" },
              "phase": { "type": "number", "description": "RF phase in radians" },
              "reads": { "type": "integer", "description": "Number of reads in this event" }
            }
          },
          "timestamp": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp" },
          "type": { "type": "string", "description": "Event type" }
        }
      }
    }
  }
}
